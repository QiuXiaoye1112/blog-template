---
import Layout from "../components/Layout.astro";
---

<Layout title="页面未找到" description="404 页面。">
  <section class="site-surface mx-auto max-w-2xl rounded-lg p-8 text-center">
    <p class="site-kicker text-sm font-semibold uppercase tracking-[0.22em]">404</p>
    <h1 class="site-title mt-4 text-3xl font-semibold">页面没有找到</h1>
    <p class="site-subtle mt-4 text-sm leading-7">
      可能是链接写错了，也可能是这部分内容还没有发布。
    </p>
    <a href="/" class="site-primary-button mt-6">
      回到首页
    </a>
  </section>
</Layout>
